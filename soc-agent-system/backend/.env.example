# SOC Agent System Configuration

# OpenAI API Configuration (optional - system works in mock mode without it)
# OPENAI_API_KEY=your_openai_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Configuration
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]

# LLM Configuration
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# Threat Generation Configuration
THREAT_GENERATION_INTERVAL=30
MAX_STORED_THREATS=100

# Redis Configuration
# Redis URL for threat storage (defaults to localhost:6379)
REDIS_URL=redis://localhost:6379

# Redis authentication (required when Redis auth is enabled in K8s)
# Set this to a strong random password: openssl rand -base64 32
# Leave empty for local dev without authentication
REDIS_PASSWORD=
